# ─────────────────────────────────────────────
# AgriAid.AI — Backend Environment Variables
# Copy this file to .env and fill in your keys
# ─────────────────────────────────────────────

# Server
PORT=3001
CLIENT_URL=http://localhost:5173
APP_URL=http://localhost:3001

# ─────────────────────────────────────────────
# AI Keys — Pick ONE or ALL (auto-fallback)
# Priority: GROQ → OPENROUTER → GEMINI
# ─────────────────────────────────────────────

# Option 1: Direct Groq (Fastest) — https://console.groq.com
GROQ_API_KEY=

# Option 2: OpenRouter (Groq + Gemini via one key) — https://openrouter.ai
OPENROUTER_API_KEY=

# Option 3: Direct Gemini — https://aistudio.google.com
GEMINI_API_KEY=

# ─────────────────────────────────────────────
# OpenWeather API — https://openweathermap.org
# ─────────────────────────────────────────────
OPENWEATHER_API_KEY=

# ─────────────────────────────────────────────
# Supabase — https://supabase.com → Project Settings → API
# ─────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
