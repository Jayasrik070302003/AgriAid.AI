# ─────────────────────────────────────────────
# AgriAid.AI — Backend Environment Variables
# ─────────────────────────────────────────────

PORT=3001
CLIENT_URL=http://localhost:5173

# ─────────────────────────────────────────────
# AI KEYS — Auto-rotation when rate limits hit
# Priority: GROQ → GROQ_2 → GEMINI → GEMINI_2
# ─────────────────────────────────────────────

# Groq Keys — https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEY_2=your_second_groq_api_key_here

# Google Gemini Keys — https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY_2=your_second_gemini_api_key_here

# ─────────────────────────────────────────────
# Supabase — https://supabase.com → Project Settings → API
# ─────────────────────────────────────────────
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
