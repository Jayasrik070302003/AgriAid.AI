# Dependencies
node_modules/
backend/node_modules/
frontend/node_modules/

# Environment Variables — NEVER commit these
.env
.env.local
.env.*.local
backend/.env
frontend/.env

# Build outputs
dist/
build/
frontend/dist/
frontend/.vite/

# Logs
logs/
*.log
backend/logs/

# Uploads — use Supabase Storage instead
backend/uploads/*
!backend/uploads/.gitkeep

# ML/AI artifacts (removed)
*.h5
*.keras
*.pt
*.pth
*.pkl

# Python
__pycache__/
*.py[cod]
venv/
.venv/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Misc debug files
*.log
*.csv

# Allow .env.example files (these are safe templates)
!*.env.example
!backend/.env.example
!frontend/.env.example
